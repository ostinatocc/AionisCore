{
  "name": "@ostinato/aionis-runtime",
  "version": "0.1.0",
  "description": "Standalone local-first Aionis Runtime package for self-evolving execution memory on a local machine.",
  "type": "module",
  "bin": {
    "aionis-runtime": "bin/aionis-runtime"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ostinatocc/AionisCore.git",
    "directory": "packages/aionis-runtime"
  },
  "homepage": "https://github.com/ostinatocc/AionisCore/tree/main/packages/aionis-runtime",
  "bugs": {
    "url": "https://github.com/ostinatocc/AionisCore/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test test/*.test.mjs",
    "pack:dry-run": "npm run build && npm pack --dry-run --json --cache /tmp/aionis-npm-cache",
    "publish:dry-run": "npm run build && npm publish --dry-run"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "fast-json-stable-stringify": "^2.1.0",
    "fastify": "^5.8.2",
    "pg": "^8.12.0",
    "tsx": "^4.19.2",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@fastify/static": "^8.3.0"
  },
  "keywords": [
    "aionis",
    "runtime",
    "lite",
    "execution-memory",
    "continuity"
  ],
  "author": "Aionis Core",
  "license": "Apache-2.0"
}
