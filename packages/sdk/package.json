{
  "name": "@cognary/aionis",
  "version": "0.1.2",
  "private": true,
  "description": "Mirrored Aionis Suite SDK surface for private runtime integration work. Publish from the public Aionis repository only.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aionis": "dist/cli.js"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cognary/Aionis.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/Cognary/Aionis/tree/main/packages/sdk",
  "bugs": {
    "url": "https://github.com/Cognary/Aionis/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "test": "node ../../node_modules/tsx/dist/cli.mjs --test test/*.test.ts",
    "pack:dry-run": "npm run build && npm pack --dry-run --json --cache /tmp/aionis-npm-cache",
    "publish:dry-run": "npm run build && npm publish --dry-run"
  },
  "keywords": [
    "aionis",
    "sdk",
    "memory",
    "agent",
    "workflow"
  ],
  "author": "Aionis Core",
  "license": "Apache-2.0"
}
