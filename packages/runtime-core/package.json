{
  "name": "@ostinato/aionis-rtc",
  "version": "0.1.0",
  "description": "Shared runtime-core boundary for Aionis Core contracts and ownership metadata.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "pack:dry-run": "npm run build && npm pack --dry-run --cache /tmp/aionis-npm-cache",
    "publish:dry-run": "npm run build && npm publish --dry-run"
  },
  "keywords": [
    "aionis",
    "runtime",
    "kernel",
    "continuity"
  ],
  "author": "Aionis Core",
  "license": "Apache-2.0"
}
