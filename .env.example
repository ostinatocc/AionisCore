AIONIS_EDITION=lite
AIONIS_MODE=local
APP_ENV=dev
AIONIS_LISTEN_HOST=127.0.0.1
MEMORY_AUTH_MODE=off
TENANT_QUOTA_ENABLED=false
RATE_LIMIT_BYPASS_LOOPBACK=true
LITE_REPLAY_SQLITE_PATH=.tmp/aionis-lite-replay.sqlite
LITE_WRITE_SQLITE_PATH=.tmp/aionis-lite-write.sqlite
LITE_LOCAL_ACTOR_ID=local-user
SANDBOX_ENABLED=true
SANDBOX_ADMIN_ONLY=false
# Optional OpenAI-compatible embeddings endpoint override, for example Moonshot/Kimi:
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=your-provider-key
# OPENAI_EMBED_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_EMBEDDING_MODEL=your-embedding-model
# Optional OpenAI-compatible governance/review model override:
# GOVERNANCE_MODEL_CLIENT_BASE_URL=https://api.moonshot.cn/v1
# GOVERNANCE_MODEL_CLIENT_API_KEY=your-provider-key
# GOVERNANCE_MODEL_CLIENT_MODEL=kimi-k2.6
# Optional practical local sandbox preset:
# LITE_SANDBOX_PROFILE=local_process_echo
# Only widen the bind host intentionally, for example behind a reverse proxy:
# AIONIS_LISTEN_HOST=0.0.0.0
