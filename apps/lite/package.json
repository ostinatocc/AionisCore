{
  "name": "aionis-lite",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local runtime shell launcher for Aionis Core",
  "scripts": {
    "build": "node --check src/index.js",
    "start": "bash ./scripts/start-lite-app.sh",
    "start:print-env": "bash ./scripts/start-lite-app.sh --print-env",
    "start:local-process": "LITE_SANDBOX_PROFILE=local_process_echo bash ./scripts/start-lite-app.sh",
    "start:local-process:print-env": "LITE_SANDBOX_PROFILE=local_process_echo bash ./scripts/start-lite-app.sh --print-env"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
