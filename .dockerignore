# Keep the Playground image small and reproducible. See Dockerfile.playground.

.git
.github
.DS_Store

# Local caches / temp
.tmp
.cache
dist
coverage
*.log

# VCS/editor noise
.vscode
.idea

# Docs site build artifacts (not needed at runtime)
apps/docs/.vitepress/.temp
apps/docs/.vitepress/cache
apps/docs/.vitepress/dist

# Inspector + Playground frontend builds (we only copy seed-pack.json explicitly
# from apps/playground/public and the seed script from apps/playground/scripts)
apps/inspector
apps/playground/node_modules
apps/playground/dist
apps/playground/src
apps/playground/index.html
apps/playground/vite.config.ts
apps/playground/tailwind.config.js
apps/playground/postcss.config.js
apps/playground/tsconfig.json
apps/playground/vercel.json
apps/playground/README.md

# Packages aren't needed to run Lite
packages

# Test and example scaffolding
examples
scripts/ci
scripts/release-verify
scripts/lite-real-task-benchmark.ts
scripts/lite-real-validation.sh
scripts/lite-smoke.sh
scripts/sync-core-path.mjs
scripts/package-release-baseline.sh
scripts/start-lite.sh

# Runtime data that must not leak into the image
node_modules
**/node_modules

# Fly / Docker metadata we don't need inside the image
fly.toml
Dockerfile*
.dockerignore
